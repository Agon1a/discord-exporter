{
	"name": "discord-exporter",
	"version": "1.1.0",
	"private": true,
	"type": "commonjs",
	"scripts": {
		"test": "npm run test:all",
		"test:exporters": "node --test tests/exporters.test.js",
		"test:phase-v": "node --test tests/phase-v.test.js",
		"test:all": "node --test tests/shared-utils.test.js tests/exporters.test.js tests/phase-v.test.js",
		"lint": "eslint src/ --fix",
		"lint:check": "eslint src/",
		"release": "node scripts/release.js",
		"release:auto": "node scripts/release.js --auto",
		"release:github": "node scripts/release.js --auto --github"
	},
	"devDependencies": {
		"eslint": "^8.56.0"
	}
}
