{
    "manifest_version": 3,
    "name": "Discord Chat Exporter",
    "version": "1.0",
    "description": "Экспорт чата Discord по диапазону дат",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://discord.com/*",
        "https://ptb.discord.com/*",
        "https://canary.discord.com/*",
        "https://discord.com/api/*",
        "https://ptb.discord.com/api/*",
        "https://canary.discord.com/api/*"
    ],
    "action": {
        "default_popup": "public/popup.html",
        "default_icon": {
            "16": "public/icons/icon16.png",
            "48": "public/icons/icon48.png",
            "128": "public/icons/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://discord.com/channels/*"
            ],
            "js": [
                "src/lib/shared-utils.js",
                "src/lib/content-utils.js",
                "src/content.js"
            ]
        }
    ]
}